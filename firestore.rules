rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isHouseholdMember(householdId) {
      return exists(/databases/$(database)/documents/household_members/$(request.auth.uid + '_' + householdId));
    }
    
    // User documents - users can only access their own data
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId);
    }
    
    // Household documents
    match /households/{householdId} {
      allow read: if isAuthenticated() && isHouseholdMember(householdId);
      allow write: if isAuthenticated() && isHouseholdMember(householdId);
      allow create: if isAuthenticated();
    }
    
    // Household members - junction table for household membership
    match /household_members/{membershipId} {
      allow read, write: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isOwner(request.auth.uid));
      allow create: if isAuthenticated();
    }
    
    // Health records - users can access their own or household members' records
    match /health_records/{recordId} {
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow write: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow create: if isAuthenticated() && 
        (isOwner(request.resource.data.userId) || isHouseholdMember(request.resource.data.householdId));
    }
    
    // Appointments - users can access their own or household members' appointments
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow write: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow create: if isAuthenticated() && 
        (isOwner(request.resource.data.userId) || isHouseholdMember(request.resource.data.householdId));
    }
    
    // Reminders - users can access their own or household members' reminders
    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow write: if isAuthenticated() && 
        (isOwner(resource.data.userId) || isHouseholdMember(resource.data.householdId));
      allow create: if isAuthenticated() && 
        (isOwner(request.resource.data.userId) || isHouseholdMember(request.resource.data.householdId));
    }
    
    // User notifications - users can only access their own notifications
    match /user_notifications/{notificationId} {
      allow read, write: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }
    
    // System notifications - read-only for all authenticated users
    match /system_notifications/{notificationId} {
      allow read: if isAuthenticated();
    }
    
    // Default deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}