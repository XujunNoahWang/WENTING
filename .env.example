# Firebase 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Google OAuth Web 客户端 ID (从 Firebase Console 获取)
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id

# Google OAuth iOS 客户端 ID (如果有 iOS 应用)
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id

# Google Calendar API 配置
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/calendar.events

# 其他配置
NODE_ENV=development