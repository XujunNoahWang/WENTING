{
  "name": "WENTING",
  "displayName": "WENTING - 家庭健康管理",
  "description": "智能家庭健康监督应用，守护全家健康",
  "version": "1.0.0",
  "versionCode": 1,
  "bundleIdentifier": "com.wenting.healthapp",
  "orientation": "portrait",
  "icon": "./src/assets/images/app-icon.png",
  "splash": {
    "image": "./src/assets/images/splash.png",
    "resizeMode": "contain",
    "backgroundColor": "#007AFF"
  },
  "updates": {
    "fallbackToCacheTimeout": 0
  },
  "assetBundlePatterns": [
    "**/*"
  ],
  "ios": {
    "supportsTablet": false,
    "bundleIdentifier": "com.wenting.healthapp",
    "buildNumber": "1",
    "infoPlist": {
      "NSCameraUsageDescription": "WENTING需要访问相机以拍摄医疗文档进行AI识别",
      "NSPhotoLibraryUsageDescription": "WENTING需要访问相册以选择医疗文档进行AI识别",
      "NSContactsUsageDescription": "WENTING需要访问通讯录以邀请家庭成员",
      "NSCalendarsUsageDescription": "WENTING需要访问日历以同步健康预约",
      "NSLocationWhenInUseUsageDescription": "WENTING需要位置信息以提供基于天气的健康建议",
      "NSUserNotificationsUsageDescription": "WENTING需要发送通知以提醒您按时用药和预约",
      "NSFaceIDUsageDescription": "WENTING使用Face ID来保护您的健康数据安全",
      "UIBackgroundModes": ["remote-notification", "background-processing"]
    }
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./src/assets/images/adaptive-icon.png",
      "backgroundColor": "#007AFF"
    },
    "package": "com.wenting.healthapp",
    "versionCode": 1,
    "permissions": [
      "android.permission.CAMERA",
      "android.permission.READ_EXTERNAL_STORAGE",
      "android.permission.WRITE_EXTERNAL_STORAGE",
      "android.permission.READ_CONTACTS",
      "android.permission.READ_CALENDAR",
      "android.permission.WRITE_CALENDAR",
      "android.permission.ACCESS_FINE_LOCATION",
      "android.permission.ACCESS_COARSE_LOCATION",
      "android.permission.VIBRATE",
      "android.permission.USE_FINGERPRINT",
      "android.permission.USE_BIOMETRIC",
      "android.permission.POST_NOTIFICATIONS"
    ]
  },
  "web": {
    "favicon": "./src/assets/images/favicon.png"
  },
  "privacy": "public"
}